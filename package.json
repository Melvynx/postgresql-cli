{
  "name": "postgresql-cli",
  "version": "0.1.0",
  "description": "CLI for managing PostgreSQL databases - register connections, run queries, inspect schemas",
  "type": "module",
  "bin": {
    "postgresql-cli": "./dist/index.js"
  },
  "scripts": {
    "build": "bun build src/index.ts --outfile dist/index.js --target bun",
    "dev": "bun run src/index.ts"
  },
  "dependencies": {
    "commander": "^13.0.0",
    "picocolors": "^1.1.0",
    "postgres": "^3.4.8"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.7.0"
  }
}
